# Alpaca API Keys (Paper or Live)
ALPACA_API_KEY=YOUR_ALPACA_API_KEY_HERE
ALPACA_SECRET_KEY=YOUR_ALPACA_SECRET_KEY_HERE
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Slack Webhook for notifications
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
DATABASE_URL=postgresql://postgres:quant_admin_123@postgres-db:5432/trading_db

# --- Risk Management & Trading Parameters ---
MAX_PORTFOLIO_RISK_PCT=0.02
KILL_SWITCH_DRAWDOWN=-0.05
PAPER_TRADE_BASE_EQUITY=10000000.0
ATR_TRAILING_MULTIPLIER=2.0
LIMIT_SLIPPAGE_BUFFER=1.005
PRE_MARKET_DROP_LIMIT=-3.0
VOLUME_SPIKE_MULTIPLIER=1.5

# --- VPS Server Deployment Credentials ---
VPS_IP=YOUR_VPS_IP_ADDRESS
VPS_ROOT_PASSWORD=YOUR_VPS_ROOT_PASSWORD

# --- Moomoo API (FutuOpenD) Credentials ---
MOOMOO_ID=YOUR_MOOMOO_LOGIN_ID
MOOMOO_PASSWORD=YOUR_MOOMOO_PASSWORD
